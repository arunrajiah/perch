# Copy this file to .env.local and fill in the values you need.
# .env.local is git-ignored and never committed.

# Optional. Enables Sentry error and performance tracking.
# Get your DSN from https://sentry.io → Project Settings → Client Keys.
EXPO_PUBLIC_SENTRY_DSN=

# Optional. Override the Sentry performance traces sample rate (0.0–1.0).
# Defaults to 0.2 when not set or when set to an invalid value.
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2
